# Copia este fichero a .env y rellena los valores
# cp .env.example .env

APP_NAME="Cuántica API"
DEBUG=true

# PostgreSQL (se levanta con docker-compose)
DATABASE_URL=postgresql://cuantica:cuantica@localhost:5432/cuantica

# Auth — genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga

# IBM Quantum — obtén tu token en: https://quantum.ibm.com/ → Account Settings → API Token
IBM_QUANTUM_TOKEN=

# LLM (pon solo el que vayas a usar)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Almacenamiento local
UPLOAD_DIR=./uploads
CHROMA_PERSIST_DIR=./chroma_db
MAX_UPLOAD_SIZE_MB=50
